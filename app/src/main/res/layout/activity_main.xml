<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="📡 TALKIE WALKIE"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="#00FF88"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="5dp"/>

        <TextView
            android:id="@+id/tvMyIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingBottom="15dp"/>

        <TextView
            android:text="CHOISIR MODE"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF88"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="15dp">

            <RadioButton
                android:id="@+id/rbWifi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📶 WiFi"
                android:textColor="#FFFFFF"
                android:buttonTint="#00FF88"/>

            <RadioButton
                android:id="@+id/rbDirect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔗 Direct"
                android:textColor="#FFFFFF"
                android:buttonTint="#00FF88"/>

            <RadioButton
                android:id="@+id/rbInternet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌍 Net"
                android:textColor="#FFFFFF"
                android:buttonTint="#00FF88"/>
        </RadioGroup>

        <!-- MODE WIFI -->
        <LinearLayout
            android:id="@+id/layoutWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="15dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:text="IP du téléphone destinataire :"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:paddingBottom="5dp"/>

            <EditText
                android:id="@+id/etTargetIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="ex: 192.168.1.15"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A3E"
                android:padding="12dp"
                android:inputType="text"/>
        </LinearLayout>

        <!-- MODE DIRECT -->
        <LinearLayout
            android:id="@+id/layoutDirect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="15dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etDirectIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="IP groupe owner (192.168.49.1)"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A3E"
                android:padding="12dp"
                android:inputType="text"/>
        </LinearLayout>

        <!-- MODE INTERNET -->
        <LinearLayout
            android:id="@+id/layoutInternet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2E"
            android:padding="15dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Votre pseudo"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A3E"
                android:padding="12dp"
                android:inputType="text"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etRoomCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Code salle (pour rejoindre)"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:background="#2A2A3E"
                android:padding="12dp"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCreate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🏠 CRÉER"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF6600"
                    android:layout_marginEnd="5dp"
                    android:visibility="gone"/>

                <Button
                    android:id="@+id/btnJoin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔗 REJOINDRE"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#9C27B0"
                    android:layout_marginStart="5dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- INFO SALLE -->
        <LinearLayout
            android:id="@+id/layoutRoom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D1F0D"
            android:padding="15dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00FF88"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="5dp"/>

            <TextView
                android:id="@+id/tvMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MODE : WiFi Local"
            android:textColor="#00AAFF"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="10dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prêt"
            android:textColor="#FFAA00"
            android:textSize="14sp"
            android:gravity="center"
            android:background="#1A1500"
            android:padding="12dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/tvPeers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aucune connexion"
            android:textColor="#666666"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="20dp"/>

        <Button
            android:id="@+id/btnPush"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:text="🎙️ MAINTENIR POUR PARLER"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnListen"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="👂 ÉCOUTER"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="30dp"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
